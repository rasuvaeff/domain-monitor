{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "php://stderr",
        "summary": "build/infection-summary.log"
    },
    "testFramework": "testo",
    "minMsi": 92,
    "mutators": {
        "@default": true,
        "global-ignore": [
            "Rasuvaeff\\DomainMonitor\\PortService::defaultConnector",
            "Rasuvaeff\\DomainMonitor\\DnsService::defaultResolver",
            "Rasuvaeff\\DomainMonitor\\SslCertificateService::openStream",
            "Rasuvaeff\\DomainMonitor\\SslCertificateService::check"
        ],
        // Equivalent mutant: idn_to_ascii already lowercases, making strtolower redundant.
        // Also causes infection formatter crash ("Incorrectly nested style tag").
        "UnwrapStrToLower": { "ignore": ["Rasuvaeff\\DomainMonitor\\HostNormalizer::normalizeAsciiHost"] }
    }
}
